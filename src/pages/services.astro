---
import Base from '@/layouts/Base.astro';
import MicroLabel from '@/components/ui/MicroLabel.astro';
import DarkSection from '@/components/ui/DarkSection.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';

const services = [
  {
    n: '01',
    name: 'Market Entry Strategies',
    lead: 'Crossing into Japan, India, or SEA.',
    body: 'We review the initial plan and help refine it in the context of the market.',
  },
  {
    n: '02',
    name: 'Cross-Cultural Advisory',
    lead: 'Working across business cultures.',
    body: 'Japanese senior executives read a proposal very differently from Indian ones. We advise CEOs and CXOs on the specific meetings they are about to walk into — not in the abstract, but in the particular.',
  },
  {
    n: '03',
    name: 'HR Advisory',
    lead: 'People strategy for multi-country operations.',
    body: 'Managing a workforce across India, Japan, and Southeast Asia requires careful alignment across different contexts. We bring senior talent strategy, compensation design, and cross-border workforce management grounded in how these markets actually work.',
  },
  {
    n: '04',
    name: 'Business Growth Advisory',
    lead: 'Partner identification, distribution, first hires.',
    body: 'Partner identification, distribution design, the right first hires, the slow building of reputation. We do this work alongside senior client teams, not as a deck from a distance.',
  },
  {
    n: '05',
    name: 'Regulatory Compliance',
    lead: 'Three jurisdictions, three regulatory regimes.',
    body: 'We work with specialist legal counsel in each market and provide the senior oversight layer that turns their advice into something a CFO can act on.',
  },
  {
    n: '06',
    name: 'Financial Advisory',
    lead: 'Led by Puneet Nayyar, FCA.',
    body: 'Strategic financial guidance for organisations working across the Japan–India corridor.',
  },
];
---

<Base
  title="Services — Reiwa Consultancy"
  description="Six shapes the work tends to take — market entry, cross-cultural advisory, HR, business growth, compliance, and financial advisory."
>

  <!-- Hero -->
  <section class="section-pad" style="background: var(--canvas); padding-top: clamp(5rem, 10vw, 8rem);">
    <div class="container-narrow">
      <MicroLabel mark class="block" style="margin-bottom: 1.75rem;">Services</MicroLabel>
      <h1 class="display-text" style="margin-bottom: 2rem; max-width: 22ch;">
        Six shapes the work<br />
        <em class="display-italic">tends to take.</em>
      </h1>
      <span class="rule" aria-hidden="true" style="display:block; margin-bottom: 2rem;"></span>
      <p class="lead">
        These are not products. A client rarely arrives needing exactly one. Most engagements cut across two or three. We describe them here as shapes — entry points into a conversation about what the work actually requires.
      </p>
    </div>
  </section>

  <!-- Services list -->
  <section class="section-pad" style="background: var(--canvas); border-top: 1px solid var(--border);">
    <div class="container-narrow">
      <ol class="service-list">
        {services.map((svc, i) => (
          <ScrollReveal client:load delay={i * 0.06}>
            <li class="service">
              <span class="service-num" aria-hidden="true">{svc.n}</span>
              <div class="service-body">
                <h2 class="service-name">
                  <span class="service-name-text">{svc.name}</span>
                  <span class="service-name-underline" aria-hidden="true"></span>
                </h2>
                <p class="service-lead">{svc.lead}</p>
                <p class="service-desc">{svc.body}</p>
              </div>
            </li>
          </ScrollReveal>
        ))}
      </ol>
    </div>
  </section>

  <!-- How to engage -->
  <DarkSection>
    <ScrollReveal client:load>
      <MicroLabel mark light class="block" style="margin-bottom: 1.5rem;">A short path</MicroLabel>
      <h2 style="font-family: 'Noto Serif', serif; font-size: clamp(1.75rem, 3.2vw, 2.5rem); font-weight: 600; color: var(--ink-inverse); line-height: 1.2; max-width: 22ch; letter-spacing: -0.022em; margin-bottom: 3rem;">
        A short path<br />
        <em class="display-italic" style="color: rgba(244,241,235,0.65);">to a first conversation.</em>
      </h2>

      <ol class="engage-steps">
        {[
          'An intro call — thirty minutes, no cost, no commitment.',
          'A scope note — what we\'d do, what we wouldn\'t, approximate timeline and fees.',
          'An engagement letter — short, signed, and we begin.',
        ].map((step, i) => (
          <li class="engage-step">
            <span class="engage-num serif-numeral" style="color: var(--accent); opacity: 0.7;">{String(i + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>

      <a href="/contact" class="arrow-link" style="margin-top: 2.75rem;">
        Start a conversation <span class="arrow">→</span>
      </a>
    </ScrollReveal>
  </DarkSection>

</Base>

<style>
  .service-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .service {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
    transition: padding var(--t-base) var(--ease-out-quint);
  }

  .service:first-child { border-top: 1px solid var(--border); }

  .service:hover { padding-left: 0.5rem; }

  .service-num {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--accent);
    opacity: 0.25;
    line-height: 1;
    min-width: 3rem;
    transition: opacity var(--t-base) var(--ease-out-quint), transform var(--t-base) var(--ease-out-quint);
  }

  .service:hover .service-num {
    opacity: 0.75;
    transform: translateX(-4px);
  }

  .service-body { min-width: 0; }

  .service-name {
    position: relative;
    display: inline-block;
    font-family: 'Noto Serif', serif;
    font-weight: 600;
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    color: var(--ink);
    letter-spacing: -0.015em;
    margin-bottom: 0.625rem;
    line-height: 1.25;
  }

  .service-name-underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--t-base) var(--ease-out-quint);
  }

  .service:hover .service-name-underline { transform: scaleX(1); }

  .service-lead {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-subtle);
    margin-bottom: 0.875rem;
    line-height: 1.5;
  }

  .service-desc {
    font-size: 1rem;
    color: var(--ink-muted);
    line-height: 1.75;
    max-width: 60ch;
  }

  @media (min-width: 720px) {
    .service { grid-template-columns: 6rem 1fr; gap: 2.5rem; }
  }

  /* Engage steps */
  .engage-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 46ch;
  }

  .engage-step {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .engage-step p {
    font-size: 1.0625rem;
    line-height: 1.7;
    opacity: 0.82;
  }

  .engage-num {
    font-size: 1.125rem;
  }
</style>

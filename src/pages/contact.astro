---
import Base from '@/layouts/Base.astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import MicroLabel from '@/components/ui/MicroLabel.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import ContactForm from '@/components/contact/ContactForm.tsx';
---

<Base
  title="Contact — Reiwa Consultancy"
  description="Start a conversation. Thirty minutes, no pitch."
>

  <!-- Hero -->
  <section class="section-pad" style="background: var(--canvas); padding-top: clamp(5rem, 10vw, 8rem);">
    <div class="container-narrow">
      <MicroLabel mark class="block" style="margin-bottom: 1.75rem;">Contact</MicroLabel>
      <h1 class="display-text" style="margin-bottom: 2rem; max-width: 18ch;">
        Start a<br />
        <em class="display-italic">conversation.</em>
      </h1>
      <span class="rule" aria-hidden="true" style="display:block; margin-bottom: 2rem;"></span>
      <p class="lead">
        Tell us briefly what you are working on. Anil or the right team member will reply within two business days. We read every message personally.
      </p>
    </div>
  </section>

  <!-- Form + details -->
  <section class="section-pad" style="background: var(--canvas); border-top: 1px solid var(--border);">
    <div class="container-narrow">
      <div class="contact-grid">

        <ScrollReveal client:load>
          <GlassCard class="form-card">
            <ContactForm client:load />
          </GlassCard>
        </ScrollReveal>

        <aside class="contact-aside">
          <ScrollReveal client:load delay={0.1}>
            <div class="aside-block">
              <MicroLabel mark class="block" style="margin-bottom: 1rem;">Or reach us directly</MicroLabel>
              <a href="mailto:info@reiwaconsultancy.in" class="aside-link">
                info@reiwaconsultancy.in
              </a>
              <a href="tel:+919818071196" class="aside-link">
                +91 98180 71196
              </a>
            </div>
          </ScrollReveal>

          <ScrollReveal client:load delay={0.2}>
            <div class="aside-block">
              <MicroLabel mark class="block" style="margin-bottom: 1rem;">Office</MicroLabel>
              <address class="aside-addr">
                Unit 914, Tower 1<br />
                Assotech Business Cresterra<br />
                Sector 135, Noida<br />
                Uttar Pradesh 201304, India
              </address>
              <a
                href="https://maps.google.com/?q=Assotech+Business+Cresterra+Sector+135+Noida"
                target="_blank"
                rel="noopener noreferrer"
                class="arrow-link"
                style="margin-top: 1rem; font-size: 0.8125rem;"
              >
                Open in Google Maps <span class="arrow">↗</span>
              </a>
            </div>
          </ScrollReveal>
        </aside>

      </div>
    </div>
  </section>

</Base>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  :global(.form-card) {
    padding: clamp(1.75rem, 3vw, 2.75rem) !important;
  }

  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .aside-block {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .aside-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .aside-link {
    display: block;
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    color: var(--accent);
    letter-spacing: -0.01em;
    line-height: 1.5;
    margin-bottom: 0.375rem;
    transition: color var(--t-fast) var(--ease-out-quint);
  }

  .aside-link:hover { color: var(--accent-hover); }

  .aside-addr {
    font-style: normal;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: var(--ink-muted);
    line-height: 1.7;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 340px;
      gap: 4rem;
    }
  }
</style>

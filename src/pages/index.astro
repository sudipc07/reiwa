---
import Base from '@/layouts/Base.astro';
import OpeningSection from '@/components/home/OpeningSection.astro';
import MomentsSection from '@/components/home/MomentsSection.astro';
import WhatThisIsSection from '@/components/home/WhatThisIsSection.astro';
import LogoCarouselSection from '@/components/home/LogoCarouselSection.astro';
import GuestBook from '@/components/home/GuestBook.astro';
import CrossroadSection from '@/components/home/CrossroadSection.astro';
---

<Base
  title="Reiwa Consultancy & Management Solutions LLP"
  description="A senior advisory practice at the Japan–India–Southeast Asia corridor."
>
  <OpeningSection />
  <MomentsSection />
  <WhatThisIsSection />
  <GuestBook />
  <LogoCarouselSection />
  <CrossroadSection />

  <!-- Voice chat (Yandle Voxa) — home page only, kept in the site's accent palette. -->
  <script
    is:inline
    src="https://yandle.io/voxa-embed.js"
    data-handle="reiwa"
    data-origin="https://yandle.io"
    data-color="#C0392B"
    data-bg="#F4F1EB"
    data-widget-theme='{"primary":"#C0392B","background":"#F4F1EB","foreground":"#1A1A1A","card":"#FAF8F3","cardForeground":"#1A1A1A","muted":"#EEE9DF","mutedForeground":"#4A4A4A","border":"rgba(22,22,26,0.08)","secondary":"#FAF8F3","accent":"#C0392B"}'
    data-position="bottom-right"
    data-label="Start a conversation"
  ></script>

  <!-- Voxa renders its panel as a 360x520 iframe; the content needs a touch
       more height so the bottom border + start-voice card don't trigger a
       scroll. Bump iframe height; safe because the iframe is on our DOM. -->
  <style is:inline>
    iframe[src*="yandle.io"] {
      height: 550px !important;
      max-height: calc(100vh - 6rem) !important;
    }
  </style>
</Base>

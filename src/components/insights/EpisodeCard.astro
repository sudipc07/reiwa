---
import type { Episode } from '@/data/episodes';
import GlassCard from '@/components/ui/GlassCard.astro';
import YouTubeLightbox from '@/components/insights/YouTubeLightbox.tsx';

interface Props {
  episode: Episode;
}
const { episode } = Astro.props;
const isPlaceholder = episode.youtubeId === 'PLACEHOLDER';
const thumbUrl = isPlaceholder
  ? null
  : `https://img.youtube.com/vi/${episode.youtubeId}/hqdefault.jpg`;
---

<YouTubeLightbox client:load youtubeId={episode.youtubeId} title={episode.title}>
  <GlassCard hover={!isPlaceholder} class="overflow-hidden">
    <!-- Thumbnail -->
    <div style="position: relative; aspect-ratio: 16/9; background: var(--canvas-dark); overflow: hidden; border-radius: 20px 20px 0 0;">
      {thumbUrl ? (
        <img src={thumbUrl} alt="" style="width: 100%; height: 100%; object-fit: cover;" />
      ) : (
        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; opacity: 0.2;">
          <span style="font-family: 'Noto Serif', serif; font-size: 0.875rem; color: var(--ink-inverse);">Episode coming soon</span>
        </div>
      )}
      {!isPlaceholder && (
        <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(15,27,46,0.35); transition: background 200ms ease;"
             onmouseover="this.style.background='rgba(15,27,46,0.5)'"
             onmouseout="this.style.background='rgba(15,27,46,0.35)'"
        >
          <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center;">
            <span style="color: white; margin-left: 3px; font-size: 1.125rem;">▶</span>
          </div>
        </div>
      )}
    </div>

    <!-- Info -->
    <div style="padding: 1.5rem;">
      <p style="font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-subtle); margin-bottom: 0.5rem; font-family: 'Inter', sans-serif;">
        Episode {episode.number}
      </p>
      <h3 style="font-family: 'Noto Serif', serif; font-weight: 600; font-size: 1rem; color: var(--ink); margin-bottom: 0.5rem; line-height: 1.4;">
        {episode.title}
      </h3>
      <p style="font-size: 0.875rem; color: var(--ink-muted); margin-bottom: 0.75rem;">
        {episode.guest} · <span style="color: var(--ink-subtle);">{episode.affiliation}</span>
      </p>
      <p style="font-size: 0.875rem; color: var(--ink-subtle); line-height: 1.6;">{episode.description}</p>
    </div>
  </GlassCard>
</YouTubeLightbox>

---
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import MicroLabel from '@/components/ui/MicroLabel.astro';
---

<section class="section-pad guest-book" style="background: var(--canvas); border-top: 1px solid var(--border);">
  <div class="container-narrow">
    <ScrollReveal client:load>
      <MicroLabel mark class="block" style="margin-bottom: 4rem;">
        From the guest book
      </MicroLabel>

      <figure class="quote-figure">
        <span class="quote-mark serif-quote-mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="quote-body">
          Reiwa read the market with us, and the business culture shaping it. We closed the project in three months. It has since grown into a much larger relationship.
        </blockquote>
        <figcaption class="quote-attrib">
          <span class="quote-rule" aria-hidden="true"></span>
          Chief Executive, Indian industrial group<span class="quote-asterisk" aria-hidden="true">*</span>
        </figcaption>
      </figure>
      <p class="quote-footnote">
        <span aria-hidden="true">*</span> Client name changed for confidentiality.
      </p>
    </ScrollReveal>
  </div>
</section>

<style>
  .quote-footnote {
    margin-top: 3rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--ink-subtle);
    letter-spacing: 0.01em;
  }

  .quote-footnote span {
    color: var(--accent);
    margin-right: 2px;
  }

  .quote-asterisk {
    color: var(--accent);
    margin-left: 2px;
    opacity: 0.8;
  }

  .quote-figure {
    position: relative;
    max-width: 58rem;
    margin: 0;
    padding: 0;
  }

  .quote-mark {
    position: absolute;
    /* Curly-quote glyph sits in the upper portion of its line box; nudge
       up so the visible apex aligns with the cap-top of "R". */
    top: -0.15em;
    left: 0;
    /* ~2.5× body so the visible character height matches R cap-height. */
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    line-height: 1;
    opacity: 0.32;
    color: var(--accent);
  }

  .quote-body {
    position: relative;
    z-index: 1;
    margin: 0;
    /* Indent the body so "Reiwa" starts to the right of the glyph. */
    padding: 0 0 0 1.6em;
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.375rem, 2.8vw, 2.125rem);
    color: var(--ink);
    line-height: 1.45;
    letter-spacing: -0.018em;
    max-width: 40ch;
  }

  .quote-attrib {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-subtle);
  }

  .quote-rule {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    /* Mobile inherits the same em-based sizing — quote-mark stays the
       size of "R" and aligned to its top. */
  }
</style>

---
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import MicroLabel from '@/components/ui/MicroLabel.astro';
---

<section class="section-pad guest-book" style="background: var(--canvas); border-top: 1px solid var(--border);">
  <div class="container-narrow">
    <ScrollReveal client:load>
      <MicroLabel mark class="block" style="margin-bottom: 2rem;">
        From the guest book
      </MicroLabel>

      <figure class="quote-figure">
        <span class="quote-mark serif-quote-mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="quote-body">
          Reiwa read the market with us, and the business culture shaping it. We closed the project in three months. It has since grown into a much larger relationship.
        </blockquote>
        <figcaption class="quote-attrib">
          <span class="quote-rule" aria-hidden="true"></span>
          Chief Executive, Indian industrial group<span class="quote-asterisk" aria-hidden="true">*</span>
        </figcaption>
      </figure>
      <p class="quote-footnote">
        <span aria-hidden="true">*</span> Client name changed for confidentiality.
      </p>
    </ScrollReveal>
  </div>
</section>

<style>
  .quote-footnote {
    margin-top: 3rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--ink-subtle);
    letter-spacing: 0.01em;
  }

  .quote-footnote span {
    color: var(--accent);
    margin-right: 2px;
  }

  .quote-asterisk {
    color: var(--accent);
    margin-left: 2px;
    opacity: 0.8;
  }

  .quote-figure {
    position: relative;
    max-width: 58rem;
    margin: 0;
    padding: 0;
  }

  .quote-mark {
    position: absolute;
    top: -3rem;
    left: -5.5rem;
    font-size: clamp(7rem, 15vw, 12rem);
    opacity: 0.32;
  }

  .quote-body {
    position: relative;
    z-index: 1;
    margin: 0;
    padding: 0;
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.375rem, 2.8vw, 2.125rem);
    color: var(--ink);
    line-height: 1.45;
    letter-spacing: -0.018em;
    max-width: 36ch;
  }

  .quote-attrib {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-subtle);
  }

  .quote-rule {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .quote-mark {
      top: -1.5rem;
      left: -1rem;
      font-size: clamp(6rem, 16vw, 9rem);
    }
    .quote-body {
      padding-left: 1.5rem;
    }
  }
</style>

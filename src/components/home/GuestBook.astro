---
import GlassCard from '@/components/ui/GlassCard.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
---

<section class="section-pad" style="background: var(--canvas); border-top: 1px solid var(--border);">
  <div class="container-narrow">
    <ScrollReveal client:load>
      <GlassCard class="p-8 md:p-12" style="max-width: 52rem;">
        <p style="font-family: 'Noto Serif', serif; font-style: italic; font-size: clamp(1.125rem, 2vw, 1.375rem); color: var(--ink); line-height: 1.75; margin-bottom: 1.5rem;">
          "We had a letter of intent signed. Two months of work with Reiwa surfaced what we had missed. We walked away. Eighteen months later we closed a better deal in the same sector."
        </p>
        <p style="font-family: 'Inter', sans-serif; font-size: 0.875rem; color: var(--ink-subtle); letter-spacing: 0.02em;">
          — Chief Executive, Indian industrial group
        </p>
      </GlassCard>
    </ScrollReveal>
  </div>
</section>

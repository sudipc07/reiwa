---
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import MicroLabel from '@/components/ui/MicroLabel.astro';
---

<section class="section-pad guest-book" style="background: var(--canvas); border-top: 1px solid var(--border);">
  <div class="container-narrow">
    <ScrollReveal client:load>
      <MicroLabel mark class="block" style="margin-bottom: 2rem;">
        From the guest book
      </MicroLabel>

      <figure class="quote-figure">
        <span class="quote-mark serif-quote-mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="quote-body">
          We had a letter of intent signed. Two months of work with Reiwa surfaced what we had missed. We walked away. Eighteen months later we closed a better deal in the same sector.
        </blockquote>
        <figcaption class="quote-attrib">
          <span class="quote-rule" aria-hidden="true"></span>
          Chief Executive, Indian industrial group
        </figcaption>
      </figure>
    </ScrollReveal>
  </div>
</section>

<style>
  .quote-figure {
    position: relative;
    max-width: 58rem;
    margin: 0;
    padding: 0;
  }

  .quote-mark {
    position: absolute;
    top: -1.5rem;
    left: -1rem;
    font-size: clamp(8rem, 18vw, 14rem);
  }

  .quote-body {
    position: relative;
    z-index: 1;
    margin: 0;
    padding: 0;
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.375rem, 2.8vw, 2.125rem);
    color: var(--ink);
    line-height: 1.38;
    letter-spacing: -0.018em;
    max-width: 36ch;
  }

  .quote-attrib {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-subtle);
  }

  .quote-rule {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  @media (min-width: 720px) {
    .quote-mark {
      top: -2rem;
      left: -2rem;
    }
  }
</style>

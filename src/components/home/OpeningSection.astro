---
import MicroLabel from '@/components/ui/MicroLabel.astro';
import CorridorLines from '@/components/home/BreathingGrid.tsx';
---

<section class="opening">
  <CorridorLines client:load />

  <div class="container-narrow opening-inner">
    <div class="opening-copy">
      <MicroLabel mark class="opening-kicker">
        Japan · India · Southeast Asia
      </MicroLabel>

      <h1 class="display-text opening-headline">
        A senior advisory practice<br />
        <em class="display-italic">at the Japan–India–Southeast Asia corridor.</em>
      </h1>

      <span class="rule opening-rule" aria-hidden="true"></span>

      <p class="lead opening-lead">
        Founded by Anil Gupta. Forty years at this interface — in the room, in both languages, on both sides of the table. He has built joint ventures, run corporations, lived inside both cultures long enough to understand what each one says, and how it is understood. Much of cross-border work happens in that space. Reiwa works within it.
      </p>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <span class="scroll-label">Scroll</span>
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .opening {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--canvas);
    isolation: isolate;
  }

  .opening-inner {
    position: relative;
    z-index: 2;
    padding-top: clamp(4rem, 9vw, 7rem);
    padding-bottom: clamp(4rem, 9vw, 7rem);
    width: 100%;
  }

  .opening-copy {
    max-width: 56rem;
  }

  .opening-kicker {
    margin-bottom: 2.25rem;
  }

  .opening-headline {
    margin-bottom: 2.75rem;
    color: var(--ink);
  }

  .opening-rule {
    margin-bottom: 2.75rem;
  }

  .opening-lead {
    max-width: 64ch;
  }

  /* Ghost glyph watermark — PNG used as mask, tinted accent red */
  .glyph-ghost {
    position: absolute;
    right: clamp(2rem, 5vw, 4rem);
    bottom: clamp(2rem, 5vw, 4rem);
    z-index: 1;
    width:  clamp(18rem, 34vw, 34rem);
    height: clamp(18rem, 34vw, 34rem);
    background-color: var(--accent);
    -webkit-mask-image: url('/reiwa-watermark.png');
            mask-image: url('/reiwa-watermark.png');
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    -webkit-mask-size: contain;
            mask-size: contain;
    -webkit-mask-position: center;
            mask-position: center;
    opacity: 0.08;
    user-select: none;
    pointer-events: none;
  }

  /* Scroll hint — vertical line + label at bottom left */
  .scroll-hint {
    position: absolute;
    left: clamp(1.5rem, 5vw, 4rem);
    bottom: 1.75rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-subtle);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .scroll-line {
    width: 1px;
    height: 44px;
    background: var(--ink-subtle);
    transform-origin: top;
    animation: scroll-hint 2600ms ease-in-out infinite;
  }

  @media (max-width: 700px) {
    .scroll-hint { display: none; }
  }
</style>

---
import MicroLabel from '@/components/ui/MicroLabel.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';

const moments = [
  {
    n: 'I',
    body: 'A Japanese mid-cap studying an Indian acquisition, uneasy about the cultural texture of the deal.',
  },
  {
    n: 'II',
    body: 'An Indian group entering Japan, with an internal plan that is likely wrong in ways they cannot yet see.',
  },
  {
    n: 'III',
    body: 'A European firm whose Southeast Asia joint venture is performing well on paper and quietly failing in the room.',
  },
  {
    n: 'IV',
    body: 'A CEO whose India office and Tokyo office are speaking past each other in a language neither realises they are speaking.',
  },
];
---

<section class="section-pad moments" style="background: var(--canvas);">
  <div class="container-narrow">

    <ScrollReveal client:load>
      <div class="moments-head">
        <MicroLabel mark class="block" style="margin-bottom: 1.75rem;">
          Moments we recognise
        </MicroLabel>

        <h2 class="moments-headline">
          Companies come to us<br />
          <em class="display-italic">at specific moments.</em>
        </h2>

        <!-- Ghost glyph, right-side, bottom-aligned with headline -->
        <span class="glyph-ghost" aria-hidden="true"></span>
      </div>
    </ScrollReveal>

    <ol class="moments-list">
      {moments.map((m, i) => (
        <ScrollReveal client:load delay={0.08 + i * 0.08}>
          <li class="moment">
            <span class="moment-numeral serif-numeral" aria-hidden="true">{m.n}</span>
            <p class="moment-body">{m.body}</p>
          </li>
        </ScrollReveal>
      ))}
    </ol>

    <ScrollReveal client:load delay={0.4}>
      <div class="moments-coda">
        <p class="moments-coda-line">
          These moments share a shape: urgency without clarity. Our first work is usually to listen, and then to slow the decision down enough that the decision becomes visible.
        </p>
        <p class="moments-coda-aside">
          If you recognise your situation in one of these, keep reading.
        </p>
      </div>
    </ScrollReveal>

  </div>
</section>

<style>
  .moments-head {
    position: relative;
  }

  .glyph-ghost {
    position: absolute;
    right: clamp(-4rem, -3vw, -1rem);
    bottom: 0;
    width:  clamp(18rem, 38vw, 34rem);
    aspect-ratio: 746 / 413;
    background-color: var(--accent);
    -webkit-mask-image: url('/reiwa-watermark.png');
            mask-image: url('/reiwa-watermark.png');
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    -webkit-mask-size: contain;
            mask-size: contain;
    -webkit-mask-position: bottom right;
            mask-position: bottom right;
    opacity: 0.1;
    user-select: none;
    pointer-events: none;
    z-index: 0;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .glyph-ghost { display: none; }
  }

  .moments-headline {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3.4vw, 2.75rem);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 3.5rem;
    max-width: 22ch;
    line-height: 1.14;
    letter-spacing: -0.025em;
  }

  .moments-list {
    list-style: none;
    padding: 0;
    margin: 0 0 3rem;
    display: flex;
    flex-direction: column;
  }

  .moment {
    display: grid;
    grid-template-columns: 3.25rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1.75rem 0;
    border-top: 1px solid var(--border);
  }

  .moment:last-child {
    border-bottom: 1px solid var(--border);
  }

  .moment-numeral {
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    font-style: italic;
    color: var(--accent);
    opacity: 0.65;
  }

  .moment-body {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    color: var(--ink);
    line-height: 1.55;
    max-width: 54ch;
    letter-spacing: -0.005em;
  }

  .moments-coda {
    max-width: 60ch;
    padding-left: 0;
  }

  .moments-coda-line {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-muted);
    line-height: 1.8;
  }

  .moments-coda-aside {
    margin-top: 1.25rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: var(--ink-subtle);
    letter-spacing: 0.01em;
  }

  @media (min-width: 720px) {
    .moment {
      grid-template-columns: 4rem 1fr;
      gap: 2.5rem;
    }
  }
</style>

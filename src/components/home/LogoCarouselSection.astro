---
import MicroLabel from '@/components/ui/MicroLabel.astro';
import LogoCarousel from '@/components/home/LogoCarousel.tsx';
---

<section class="logos-section" style="background: var(--canvas); border-top: 1px solid var(--border); overflow: hidden;">
  <div class="container-narrow" style="padding-top: 3.5rem; padding-bottom: 0.5rem;">
    <MicroLabel mark class="block" style="margin-bottom: 0.5rem;">
      A partial record
    </MicroLabel>
    <p class="caption">
      Organisations whose senior teams we have worked with directly, alongside their leadership.
    </p>
  </div>

  <LogoCarousel client:load />
</section>

<style>
  .caption {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-subtle);
    max-width: 52ch;
    line-height: 1.6;
  }

  .logos-section > :global(section),
  .logos-section > :global(div.carousel-wrap) {
    padding-top: 1.5rem;
    padding-bottom: 3.5rem;
  }
</style>

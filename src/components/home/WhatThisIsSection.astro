---
import MicroLabel from '@/components/ui/MicroLabel.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import CorridorDiagram from '@/components/home/CorridorDiagram.tsx';
---

<section class="section-pad what-this-is" style="background: var(--canvas); border-top: 1px solid var(--border);">
  <div class="container-narrow">
    <div class="grid">

      <ScrollReveal client:load>
        <div class="copy">
          <MicroLabel mark class="block" style="margin-bottom: 1.75rem;">
            What this practice offers
          </MicroLabel>

          <h2 class="headline">
            Judgment.<br />
            <em class="display-italic">Not scale, not frameworks, not a delivery team.</em>
          </h2>

          <span class="rule" aria-hidden="true" style="margin-bottom: 2rem;"></span>

          <div class="stack-lg" style="max-width: 56ch;">
            <p style="font-size: 1.0625rem; color: var(--ink-muted); line-height: 1.75;">
              Every Reiwa engagement is led by a named senior practitioner — someone who has operated in the room, in both languages.
            </p>
            <p style="font-size: 1.0625rem; color: var(--ink-muted); line-height: 1.75;">
              We work where that kind of judgment is worth the premium. We decline where it isn&rsquo;t.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal client:load delay={0.2}>
        <aside class="diagram-frame">
          <CorridorDiagram client:load />
          <p class="diagram-caption">
            Three markets, one team. Every engagement led personally.
          </p>
        </aside>
      </ScrollReveal>

    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  .headline {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3.4vw, 2.75rem);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 2rem;
    max-width: 22ch;
    line-height: 1.14;
    letter-spacing: -0.025em;
  }

  .diagram-frame {
    position: relative;
    padding: 2rem clamp(1rem, 3vw, 2.5rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1));
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .diagram-caption {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--ink-subtle);
    line-height: 1.6;
    max-width: 36ch;
  }

  @media (min-width: 900px) {
    .grid {
      grid-template-columns: 1.15fr 1fr;
      gap: 5rem;
    }
  }
</style>

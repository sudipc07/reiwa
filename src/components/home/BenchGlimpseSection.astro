---
import MicroLabel from '@/components/ui/MicroLabel.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import BenchGlimpse from '@/components/home/BenchGlimpse.tsx';
---

<section class="section-pad bench-glimpse" style="background: var(--canvas-warm); border-top: 1px solid var(--border); overflow: hidden;">
  <div class="container-narrow" style="margin-bottom: 2.5rem;">
    <div class="head">
      <ScrollReveal client:load>
        <MicroLabel mark class="block" style="margin-bottom: 1.5rem;">
          The bench
        </MicroLabel>
        <h2 class="headline">
          Eleven senior practitioners.<br />
          <em class="display-italic">Each engaged personally. None behind a curtain.</em>
        </h2>
      </ScrollReveal>

      <div class="count" aria-hidden="true">
        <span class="count-num">11</span>
        <span class="count-caption">members of the bench</span>
      </div>
    </div>
  </div>

  <BenchGlimpse client:load />

  <div class="container-narrow" style="margin-top: 2.5rem;">
    <a href="/bench" class="arrow-link">
      Meet the bench <span class="arrow">→</span>
    </a>
  </div>
</section>

<style>
  .head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: end;
  }

  .headline {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 2.8vw, 2.125rem);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
    max-width: 30ch;
    letter-spacing: -0.022em;
  }

  .count {
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .count-num {
    font-family: 'Noto Serif', serif;
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .count-caption {
    margin-top: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-subtle);
  }

  @media (min-width: 800px) {
    .head {
      grid-template-columns: 1fr auto;
      gap: 3rem;
    }

    .count {
      align-items: flex-end;
    }
  }
</style>

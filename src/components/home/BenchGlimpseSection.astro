---
import MicroLabel from '@/components/ui/MicroLabel.astro';
import ScrollReveal from '@/components/ui/ScrollReveal.tsx';
import BenchGlimpse from '@/components/home/BenchGlimpse.tsx';
---

<section class="section-pad" style="background: var(--canvas); border-top: 1px solid var(--border); overflow: hidden;">
  <ScrollReveal client:load>
    <div class="container-narrow" style="margin-bottom: 2rem;">
      <MicroLabel class="mb-4 block">The bench</MicroLabel>
      <p style="font-family: 'Noto Serif', serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 600; color: var(--ink); line-height: 1.3; max-width: 36ch; letter-spacing: -0.015em;">
        Eleven senior practitioners. Each engaged personally. None behind a curtain.
      </p>
    </div>
  </ScrollReveal>

  <BenchGlimpse client:load />

  <div class="container-narrow" style="margin-top: 2rem;">
    <a href="/bench" style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; color: var(--accent); text-decoration: none; display: inline-flex; align-items: center; gap: 0.375rem; transition: gap 150ms ease;"
       onmouseover="this.style.gap='0.625rem'"
       onmouseout="this.style.gap='0.375rem'"
    >
      → Meet the bench
    </a>
  </div>
</section>

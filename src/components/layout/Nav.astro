---
const navLinks = [
  { href: '/',         label: 'Home' },
  { href: '/practice', label: 'Practice' },
  { href: '/team',     label: 'Team' },
  { href: '/services', label: 'Services' },
  { href: '/insights', label: 'Insights' },
  { href: '/contact',  label: 'Contact' },
];

const leftLinks  = navLinks.slice(0, 3);
const rightLinks = navLinks.slice(3);

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="site-nav" aria-label="Primary">

  <!-- Shoji lattice: kumiko vertical members across the nav -->
  <span class="shoji-lattice" aria-hidden="true"></span>
  <span class="shoji-rail shoji-rail-top" aria-hidden="true"></span>
  <span class="shoji-rail shoji-rail-bottom" aria-hidden="true"></span>

  <div class="nav-inner container-narrow">

    <nav aria-label="Main (left)" class="desktop-nav desktop-nav-left">
      <ul>
        {leftLinks.map(link => (
          <li>
            <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
              <span class="nav-label">{link.label}</span>
              <span class="nav-underline" aria-hidden="true"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/" aria-label="Reiwa Consultancy home" class="brand">
      <!-- Hanko seal: red square stamp impression on washi -->
      <span class="hanko">
        <span class="hanko-halo" aria-hidden="true"></span>
        <span class="hanko-plate">
          <img src="/logo-rewa-1-1.png" alt="" width="160" height="160" class="brand-mark" />
        </span>
      </span>
      <span class="brand-wordmark">
        <span class="brand-line1">Reiwa Consultancy</span>
        <span class="brand-line2">&amp; Management Solutions <span class="brand-llp">LLP</span></span>
      </span>
    </a>

    <nav aria-label="Main (right)" class="desktop-nav desktop-nav-right">
      <ul>
        {rightLinks.map(link => (
          <li>
            <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
              <span class="nav-label">{link.label}</span>
              <span class="nav-underline" aria-hidden="true"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      id="nav-toggle"
      class="mobile-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
    </button>
  </div>

  <nav id="mobile-nav" aria-label="Mobile" class="mobile-nav">
    <ul>
      {navLinks.map(link => (
        <li>
          <a href={link.href} class:list={['mobile-link', { active: isActive(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  #site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    isolation: isolate;
    padding-bottom: 3rem;
    background:
      linear-gradient(180deg, rgba(246, 243, 237, 0.92) 0%, rgba(244, 241, 235, 0.82) 100%);
    backdrop-filter: blur(22px) saturate(1.12);
    -webkit-backdrop-filter: blur(22px) saturate(1.12);
    transition:
      background 380ms cubic-bezier(0.22, 1, 0.36, 1),
      padding-bottom 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #site-nav[data-scrolled='true'] {
    padding-bottom: 1.25rem;
  }

  /* Washi paper grain — barely there */
  #site-nav::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 18% 20%, rgba(192,57,43,0.035) 0, transparent 42%),
      radial-gradient(circle at 82% 70%, rgba(0,0,0,0.025) 0, transparent 48%);
    pointer-events: none;
    z-index: -1;
  }

  /* Kumiko vertical members — evenly spaced hairlines */
  .shoji-lattice {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg,
        transparent 0,
        transparent calc(12.5% - 0.5px),
        rgba(40, 30, 22, 0.09) calc(12.5% - 0.5px),
        rgba(40, 30, 22, 0.09) 12.5%,
        transparent 12.5%);
    background-size: 100% 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.9;
    transition: opacity var(--t-base) var(--ease-out-quint);
  }

  /* Horizontal shoji rails (top + bottom frame) */
  .shoji-rail {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(40, 30, 22, 0.18) 8%,
      rgba(40, 30, 22, 0.22) 50%,
      rgba(40, 30, 22, 0.18) 92%,
      transparent 100%);
    pointer-events: none;
    z-index: 1;
  }
  .shoji-rail-top    { top: 0; }
  .shoji-rail-bottom { bottom: 0; }

  #site-nav[data-scrolled='true'] .shoji-rail-bottom {
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(40, 30, 22, 0.28) 50%,
      transparent 100%);
  }

  /* 令和 kanji watermark, far right */
  .nav-kanji {
    position: absolute;
    right: clamp(1rem, 3vw, 2.5rem);
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Noto Serif TC', 'Noto Serif', serif;
    font-weight: 600;
    font-size: 3.25rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.065;
    letter-spacing: 0.08em;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    transition: opacity var(--t-base) var(--ease-out-quint);
  }

  .nav-inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    column-gap: clamp(1.5rem, 4vw, 3.5rem);
    height: 5.25rem;
    transition: height var(--t-base) var(--ease-out-quint);
    z-index: 2;
  }

  #site-nav[data-scrolled='true'] .nav-inner {
    height: 4.25rem;
  }

  /* ===== Brand / Hanko seal ===== */
  .brand {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    justify-self: center;
    gap: 0.55rem;
    transform-origin: top center;
    will-change: transform;
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 3;
  }

  #site-nav[data-scrolled='true'] .brand {
    transform: scale(0.68);
  }

  .hanko {
    position: relative;
    width: 128px;
    height: 128px;
    display: grid;
    place-items: center;
    transform: translateY(44px);
  }

  /* Soft halo behind the seal */
  .hanko-halo {
    position: absolute;
    inset: -12px;
    background: radial-gradient(circle, rgba(192,57,43,0.28) 0%, rgba(192,57,43,0) 62%);
    filter: blur(8px);
    z-index: 0;
    opacity: 0.8;
    transition: opacity var(--t-base) var(--ease-out-quint);
  }

  /* Ink-bloom ripple — sits behind the plate, expands on hover */
  .hanko::before {
    content: '';
    position: absolute;
    inset: 4px;
    border-radius: 8px;
    background: radial-gradient(circle, rgba(192,57,43,0.55) 0%, rgba(192,57,43,0) 70%);
    opacity: 0;
    transform: scale(0.85);
    pointer-events: none;
    z-index: 0;
  }

  .brand:hover .hanko::before {
    animation: ink-bloom 1400ms var(--ease-out-quint) forwards;
  }

  @keyframes ink-bloom {
    0%   { opacity: 0;    transform: scale(0.9); }
    40%  { opacity: 0.45; transform: scale(1.08); }
    100% { opacity: 0;    transform: scale(1.35); }
  }

  /* The plate — washi card with a red ink border (hanko feel) */
  .hanko-plate {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 35% 28%, #fffdf8 0%, #f6f2ea 55%, #ece6d7 100%);
    border-radius: 6px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.95) inset,
      0 0 0 1px rgba(192, 57, 43, 0.55),
      0 16px 32px -14px rgba(192, 57, 43, 0.40),
      0 14px 40px -14px rgba(0, 0, 0, 0.28),
      0 2px 8px rgba(0,0,0,0.08);
    transform: rotate(-2.5deg);
    transition:
      transform var(--t-base) var(--ease-out-quint),
      box-shadow var(--t-base) var(--ease-out-quint);
    z-index: 1;
  }

  /* Inner red hairline — like the inner line of a real hanko */
  .hanko-plate::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(192, 57, 43, 0.35);
    border-radius: 3px;
    pointer-events: none;
  }

  /* Corner crop marks (tokonoma scroll feel) */
  .hanko-plate::after {
    content: '';
    position: absolute;
    inset: -10px;
    border-top:    1px solid rgba(40, 30, 22, 0.22);
    border-bottom: 1px solid rgba(40, 30, 22, 0.22);
    border-left:   1px solid rgba(40, 30, 22, 0);
    border-right:  1px solid rgba(40, 30, 22, 0);
    border-radius: 0;
    pointer-events: none;
    width: 28%;
    height: calc(100% + 20px);
    left: 50%;
    transform: translateX(-50%);
  }

  .brand-mark {
    position: relative;
    z-index: 2;
    width: 92px;
    height: 92px;
    object-fit: contain;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.08));
    transition: width var(--t-base) var(--ease-out-quint),
                height var(--t-base) var(--ease-out-quint);
  }

  .brand:hover .hanko-plate {
    transform: rotate(2deg) translateY(-3px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.95) inset,
      0 0 0 1.25px rgba(192, 57, 43, 0.85),
      0 10px 22px -10px rgba(192, 57, 43, 0.55),
      0 20px 40px -14px rgba(0, 0, 0, 0.30),
      0 2px 8px rgba(0,0,0,0.10);
  }

  .brand-mark {
    transition: filter var(--t-base) var(--ease-out-quint),
                width  var(--t-base) var(--ease-out-quint),
                height var(--t-base) var(--ease-out-quint);
  }

  .brand:hover .brand-mark {
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.10)) saturate(1.12) contrast(1.04);
  }

  .brand:hover .hanko-halo { opacity: 1; }

  #site-nav[data-scrolled='true'] .hanko {
    width: 82px;
    height: 82px;
    transform: translateY(24px);
  }
  #site-nav[data-scrolled='true'] .brand-mark { width: 60px; height: 60px; }

  .brand-wordmark {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.2;
    text-align: center;
    margin-top: 62px;
    transition: margin-top var(--t-base) var(--ease-out-quint),
                opacity var(--t-base) var(--ease-out-quint);
  }

  #site-nav[data-scrolled='true'] .brand-wordmark {
    margin-top: 30px;
    opacity: 0.85;
  }

  .brand-line1 {
    font-family: 'Noto Serif', serif;
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--ink);
    letter-spacing: 0.005em;
  }

  .brand-line2 {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--ink-subtle);
    letter-spacing: 0.2em;
    margin-top: 0.2rem;
    text-transform: uppercase;
  }

  .brand-llp { letter-spacing: 0.3em; }

  /* ===== Desktop nav (split) ===== */
  .desktop-nav { display: none; }

  .desktop-nav ul {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 2.8vw, 2.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .desktop-nav-left ul  { justify-content: flex-end; }
  .desktop-nav-right ul { justify-content: flex-start; }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.35rem 0.1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color var(--t-fast) var(--ease-out-quint);
  }

  .nav-link:hover { color: var(--ink); }
  .nav-link.active { color: var(--ink); }

  .nav-link.active::before {
    content: '';
    width: 5px;
    height: 5px;
    background: var(--accent);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .nav-underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--t-base) var(--ease-out-quint);
  }

  .nav-link:hover .nav-underline {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-link.active .nav-underline { display: none; }

  /* ===== Mobile ===== */
  .mobile-toggle {
    position: absolute;
    right: clamp(1.25rem, 4vw, 2rem);
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    justify-content: center;
    z-index: 4;
  }

  .mobile-toggle .bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition: transform var(--t-base) var(--ease-out-quint),
                opacity var(--t-base) var(--ease-out-quint);
  }

  .mobile-toggle[aria-expanded='true'] .bar-1 {
    transform: translateY(3.75px) rotate(45deg);
  }

  .mobile-toggle[aria-expanded='true'] .bar-2 {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  .mobile-nav {
    display: none;
    border-top: 1px solid var(--border);
    background: rgba(244, 241, 235, 0.98);
    backdrop-filter: blur(18px);
    position: relative;
    z-index: 3;
  }

  .mobile-nav.open { display: block; }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 0 1.5rem;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem clamp(1.5rem, 5vw, 4rem);
    font-family: 'Inter', sans-serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
  }

  .mobile-link.active { color: var(--accent); }

  .mobile-link.active::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  @media (min-width: 860px) {
    .desktop-nav { display: block; }
    .mobile-toggle { display: none; }
  }

  @media (max-width: 859px) {
    .shoji-lattice {
      background-image:
        linear-gradient(90deg,
          transparent 0,
          transparent calc(25% - 0.5px),
          rgba(40, 30, 22, 0.09) calc(25% - 0.5px),
          rgba(40, 30, 22, 0.09) 25%,
          transparent 25%);
    }
    .nav-inner {
      grid-template-columns: 1fr;
      justify-items: center;
    }
    .hanko { width: 102px; height: 102px; transform: translateY(30px); }
    .brand-mark { width: 72px; height: 72px; }
    .brand-wordmark { margin-top: 38px; }
    #site-nav[data-scrolled='true'] .hanko {
      width: 68px; height: 68px; transform: translateY(20px);
    }
    #site-nav[data-scrolled='true'] .brand-mark { width: 50px; height: 50px; }
    #site-nav[data-scrolled='true'] .brand-wordmark { margin-top: 22px; }
    .nav-kanji { font-size: 2.25rem; opacity: 0.05; }
  }

  @media (max-width: 420px) {
    .brand-line2 { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hanko, .hanko-plate, .brand-mark, .brand-wordmark, .nav-inner,
    .shoji-rail, .shoji-lattice, .nav-kanji {
      transition: none !important;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('mobile-nav');

  const onScroll = () => {
    if (!nav) return;
    nav.setAttribute('data-scrolled', String(window.scrollY > 8));
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobile?.classList.toggle('open', !expanded);
  });

  mobile?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      mobile.classList.remove('open');
    })
  );
</script>

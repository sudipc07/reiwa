---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/practice', label: 'Practice' },
  { href: '/bench', label: 'Bench' },
  { href: '/services', label: 'Services' },
  { href: '/insights', label: 'Insights' },
  { href: '/contact', label: 'Contact' },
];
---

<footer style="background: var(--canvas); border-top: 1px solid var(--border); padding: clamp(3rem, 6vw, 5rem) 0 2rem;">
  <div class="container-narrow">
    <div style="display: grid; grid-template-columns: 1fr; gap: 3rem; margin-bottom: 3rem;">

      <!-- Column 1: Logo + tagline -->
      <div>
        <a href="/" style="display: flex; align-items: center; gap: 0.75rem; text-decoration: none; margin-bottom: 1rem;">
          <img src="/logo-rewa-1-1.png" alt="Reiwa logo" width="36" height="36" style="width: 36px; height: 36px; object-fit: contain;" />
          <div style="line-height: 1.2;">
            <div style="font-family: 'Noto Serif', serif; font-weight: 600; font-size: 0.875rem; color: var(--ink);">Reiwa Consultancy</div>
            <div style="font-family: 'Inter', sans-serif; font-size: 0.6875rem; color: var(--ink-subtle); letter-spacing: 0.05em; font-variant: small-caps;">&amp; Management Solutions LLP</div>
          </div>
        </a>
        <p style="font-size: 0.875rem; color: var(--ink-muted); line-height: 1.6; max-width: 28ch;">
          A senior advisory practice at the Japan–India–Southeast Asia corridor.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <p class="micro-label" style="margin-bottom: 1rem;">Navigation</p>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {navLinks.map(link => (
            <li>
              <a href={link.href} style="font-size: 0.875rem; color: var(--ink-muted); text-decoration: none; transition: color 150ms ease;"
                 onmouseover="this.style.color='var(--ink)'"
                 onmouseout="this.style.color='var(--ink-muted)'"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <p class="micro-label" style="margin-bottom: 1rem;">Contact</p>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href="mailto:info@reiwaconsultancy.in" style="font-size: 0.875rem; color: var(--ink-muted); text-decoration: none; transition: color 150ms ease;"
             onmouseover="this.style.color='var(--accent)'"
             onmouseout="this.style.color='var(--ink-muted)'"
          >info@reiwaconsultancy.in</a>
          <a href="tel:+919818071196" style="font-size: 0.875rem; color: var(--ink-muted); text-decoration: none; transition: color 150ms ease;"
             onmouseover="this.style.color='var(--accent)'"
             onmouseout="this.style.color='var(--ink-muted)'"
          >+91 98180 71196</a>
          <p style="font-size: 0.8125rem; color: var(--ink-subtle); line-height: 1.5; margin-top: 0.25rem;">
            Unit 914, Tower 1<br />
            Assotech Business Cresterra<br />
            Sector 135, Noida, UP 201304
          </p>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid var(--border); padding-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; align-items: center;">
      <p style="font-size: 0.75rem; color: var(--ink-subtle);">
        © {new Date().getFullYear()} Reiwa Consultancy &amp; Management Solutions LLP
      </p>
      <p style="font-size: 0.75rem; color: var(--ink-subtle);">
        Japan · India · SEA
      </p>
    </div>
  </div>
</footer>

<style>
  @media (min-width: 768px) {
    footer > div > div:first-of-type {
      grid-template-columns: 2fr 1fr 1fr !important;
    }
  }
</style>
